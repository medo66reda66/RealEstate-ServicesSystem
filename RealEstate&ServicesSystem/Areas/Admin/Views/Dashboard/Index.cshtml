@using RealEstate_ServicesSystem.Utilities.DBinitializer
<div class="main">

    <!-- TOP CARDS -->
    <div class="row g-3">
        @if (User.IsInRole(DS.Role_Admin) || User.IsInRole(DS.Role_Employee))
        {
            <div class="col-md-3">
                <div class="stat-box">
                    <h6>Total Properties</h6>
                    <h3 id="pCount">120</h3>
                </div>
            </div>
           
        }else
        {
             <div class="col-md-3">
                <div class="stat-box">
                    <h6></h6>
                    <h3 id="pCount">120</h3>
                </div>
            </div>
        }
        @if (User.IsInRole(DS.Role_Admin) || User.IsInRole(DS.Role_Employee) || User.IsInRole(DS.Role_Agent) || User.IsInRole(DS.Role_Owner))
        {
         <div class="col-md-3">
                <div class="stat-box">
                <h6>Units</h6>
                <h3 id="uCount">340</h3>
                </div>
            </div>
        }else
        {
           <div class="col-md-3">
                <div class="stat-box">
                <h6></h6>
                <h3 id="uCount">340</h3>
                </div>
            </div>
        }
        @if (User.IsInRole(DS.Role_Admin) || User.IsInRole(DS.Role_Employee) )
        {
            <div class="col-md-3">
                <div class="stat-box">
                <h6>Listings</h6>
                <h3 id="lCount">98</h3>
                </div>
            </div>
        }else
        {
            <div class="col-md-3">
                <div class="stat-box">
                    <h6> </h6>
                    <h3 id="lCount">98</h3>
                </div>
            </div>
        }
        @if (User.IsInRole(DS.Role_Admin) || User.IsInRole(DS.Role_Employee))
        {
            <div class="col-md-3">
                <div class="stat-box">
                <h6>Requests</h6>
                <h3 id="rCount">56</h3>
                </div>
            </div>
        }
      </div>
        

    <!-- CHART -->
    <div class="row mt-4">
        <div class="col-md-8">
            <div class="card card-dark p-3">
                <h6>Activity Overview</h6>
                <canvas id="chart"></canvas>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card card-dark p-3">
                <h6>Recent Requests</h6>
                <ul class="list-group list-group-flush" id="reqList"></ul>
            </div>
        </div>
    </div>
    <!-- TABLE -->
    <div class="card card-dark mt-4 p-3">
        <h6>Latest Listings</h6>
        <table class="table table-dark table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Unit</th>
                    <th>Price</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody id="listingTable"></tbody>
        </table>
    </div>

</div>

<script>
    // fake dynamic data
    const requests=["Visit request","Buy inquiry","Rent request","Inspection","Question"];
    const listings=[
      {id:1,unit:"101",price:"1.5M",status:"Active"},
      {id:2,unit:"202",price:"2.2M",status:"Pending"},
      {id:3,unit:"303",price:"3.1M",status:"Active"}
    ];

    // render requests
    let reqList=document.getElementById("reqList");
    requests.forEach(r=>{
      reqList.innerHTML+=`<li class='list-group-item bg-transparent text-white'>${r}</li>`;
    });

    // render table
    let table=document.getElementById("listingTable");
    listings.forEach(l=>{
      table.innerHTML+=`<tr><td>${l.id}</td><td>${l.unit}</td><td>${l.price}</td><td>${l.status}</td></tr>`;
    });

    // chart
    new Chart(document.getElementById('chart'),{
      type:'line',
      data:{
        labels:['Jan','Feb','Mar','Apr','May'],
        datasets:[{
          label:'Activity',
          data:[10,20,15,30,25],
          borderColor:'#4e8cff'
        }]
      }
    });
</script>
