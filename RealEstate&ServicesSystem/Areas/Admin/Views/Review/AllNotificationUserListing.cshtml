@using RealEstate_ServicesSystem.Viewmodel
@model  AllReview

@section Scripts {

    @if (TempData["success"] != null)
    {
        <script>
              toastr.options = {
                  "closeButton": false,
                  "debug": false,
                  "newestOnTop": false,
                  "progressBar": true,
                  "positionClass": "toast-top-center",
                  "preventDuplicates": false,
                  "onclick": null,
                  "showDuration": "300",
                  "hideDuration": "1000",
                  "timeOut": "5000",
                  "extendedTimeOut": "1000",
                  "showEasing": "swing",
                  "hideEasing": "linear",
                  "showMethod": "fadeIn",
                  "hideMethod": "fadeOut"
                }

            toastr.success('@TempData["success"]');

        </script>
    }
}

<div class="reviews-container">

    <div class="reviews-header">
        <h2>📢 Listing Reviews</h2>
    </div>

    @if (Model.reviews == null || !Model.reviews.Any())
    {
        <div class="empty-state">
            <p>No reviews available yet.</p>
        </div>
    }
    else
    {
        <div class="reviews-grid">
            @foreach (var review in Model.reviews)
            {
                <div class="review-card">

                    <div class="review-top">
                        <div class="user-info">
                            <div class="avatar">
                                @review.User.FullName.Substring(0, 1)
                            </div>
                            <div>
                                <h4>@review.User.FullName</h4>
                                <span>@review.CreatedAt.ToString("MMM dd, yyyy")</span>
                            </div>
                        </div>

                        <div class="rating">
                            ⭐ @review.Rating / 5
                        </div>
                    </div>

                    <div class="review-body">
                        <p>@review.Comment</p>
                    </div>

                </div>
            }
        </div>
        <div class="back-container">
            <a href="/User/Home/Details/@Model.listingId" class="btn back-to-listing-btn">
                ⬅ Back to Listing
            </a>
        </div>
    }
</div>
<style>
    .back-container {
        display: flex;
        justify-content: center;
        margin-top: 30px;
    }
    .back-to-listing-btn {
        background: #ffffff;
        color: #1f2937;
        border: 1px solid #d1d5db;
        padding: 12px 20px;
        border-radius: 12px;
        font-weight: bold;
        text-decoration: none;
        transition: 0.3s ease;
        box-shadow: 0 6px 15px rgba(0,0,0,0.08);
    }
        .back-to-listing-btn:hover {
            background: #f3f4f6;
            transform: translateY(-3px);
            color: #111827;
        }
    .reviews-container {
        padding: 30px;
        background: #f6f8fb;
        min-height: 100vh;
        font-family: Arial, sans-serif;
    }

    .reviews-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
    }

        .reviews-header h2 {
            font-size: 26px;
            color: #222;
        }

    .add-review-btn {
        background: #4f46e5;
        color: #fff;
        padding: 10px 18px;
        border-radius: 10px;
        text-decoration: none;
        transition: 0.3s;
        font-weight: bold;
    }

        .add-review-btn:hover {
            background: #3730a3;
        }

    .reviews-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 20px;
    }

    .review-card {
        background: #fff;
        border-radius: 16px;
        padding: 18px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.08);
        transition: 0.3s;
    }

        .review-card:hover {
            transform: translateY(-5px);
        }

    .review-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
    }

    .user-info {
        display: flex;
        align-items: center;
        gap: 10px;
        color:blue;
    }

    .avatar {
        width: 42px;
        height: 42px;
        background: #4f46e5;
        color: white;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        font-weight: bold;
    }

    .user-info h4 {
        margin: 0;
        font-size: 15px;
    }

    .user-info span {
        font-size: 12px;
        color: #777;
    }

    .rating {
        background: #fff7e6;
        color: #b45309;
        padding: 6px 10px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: bold;
    }

    .review-body p {
        color: #444;
        line-height: 1.6;
        margin: 0;
    }

    .empty-state {
        text-align: center;
        padding: 50px;
        color: #777;
        font-size: 18px;
    }
</style>