@model RealEstate_ServicesSystem.Viewmodel.AddListingmodel


<div class="form-card">
    <h3>➕ Add New Listing</h3>

    @if (Model.Applicationuser.paid)
    {
        <div class="payment-box" style="background: #2e7d32; border-color: #1b5e20;">
            <label>✅ Payment completed! You can now fill the listing details.</label>
        </div>
    }
    else
    {
        <div class="payment-box">
            <label>لازم تروح للدفع الأول قبل ما تملأ البيانات</label>
            <a href="/Identity/Payment/Pay/@Model.Units.Id" class="payment-btn">
                💳 Go to payment — 200 EGP
            </a>
        </div>
    }
 </div>

    <form method="post">

        <div class="form-grid">

           <input type="hidden" asp-for="@Model.Units.Property.ApplicationuserId" />
           <input type="hidden" asp-for="@Model.Units" />

            <!-- Unit -->
            <select asp-for="UnitId">
                <option value="@Model.Units.Id">@Model.Units.UnitNumber</option>
            </select>
            <!-- Broker Percentage -->
            
            <input asp-for="BrokerPercentage" placeholder="Broker % نسبتك" />
            <span class="text-danger" asp-validation-for="BrokerPercentage"></span>

            <!-- Listing Type -->
            <!-- Listing Type -->
            @if (Model.Units.Purpose == UnitPurpose.Rent)
            {
                <div id="rentPeriodContainer">
                    <select asp-for="Rentperiod"
                        id="rentPeriod"
                        asp-items="Html.GetEnumSelectList<RentPeriod>()">
                    <option value="">Rent Period</option>
                </select>
                <span class="text-danger" asp-validation-for="Rentperiod"></span>
                </div>
            }else
            {
                
            }

            <!-- Is Active -->
            <select asp-for="IsActive">
                <option value="true" selected>Active</option>
                <option value="false">Inactive</option>
            </select>

        </div>

        <!-- Description -->
        <textarea asp-for="Description" placeholder="Description"></textarea>
        <span class="text-danger" asp-validation-for="Description"></span>

        <button type="submit" class="btn btn-primary" @(Model.Applicationuser.paid ? "" : "disabled")>
            Submit
        </button>

    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .payment-box {
        background: #1e1e2f;
        padding: 20px;
        border-radius: 15px;
        text-align: center;
        margin-bottom: 20px;
        border: 1px solid #2e2e40;
    }

        .payment-box label {
            display: block;
            font-size: 18px;
            color: #ffffff;
            margin-bottom: 15px;
        }

    .payment-btn {
        display: inline-block;
        padding: 10px 20px;
        border-radius: 10px;
        text-decoration: none;
        background: linear-gradient(45deg, #0d6efd, #198754);
        color: white;
        font-weight: bold;
        transition: 0.3s ease;
    }

        .payment-btn:hover {
            transform: scale(1.05);
            background: linear-gradient(45deg, #198754, #0d6efd);
        }
    button:disabled {
        background: #ccc;
        cursor: not-allowed;
    }

    button.active {
        background: linear-gradient(45deg, #198754, #0d6efd);
        color: white;
        transform: scale(1.05);
    }
    /* 🔳 Card */
    .form-card {
        background: #1e1e2f;
        padding: 20px;
        border-radius: 12px;
        color: white;
        max-width: 1200px;
        margin: 20px auto;
    }

        /* Title */
        .form-card h3 {
            margin-bottom: 20px;
        }

    /* Grid */
    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
    }

        /* Inputs */
        .form-grid input,
        .form-grid select {
            padding: 10px;
            border-radius: 8px;
            border: none;
            outline: none;
            background: #2b2b3d;
            color: white;
        }

    /* Textarea */
    textarea {
        width: 100%;
        margin-top: 12px;
        padding: 10px;
        border-radius: 8px;
        border: none;
        background: #2b2b3d;
        color: white;
    }

    /* Button */
    .submit-btn {
        width: 100%;
        margin-top: 15px;
        padding: 12px;
        background: #28a745;
        border: none;
        border-radius: 10px;
        color: white;
        font-size: 16px;
        cursor: pointer;
        transition: 0.3s;
    }

        .submit-btn:hover {
            background: #218838;
        }

    /* 📱 Responsive */
     (max-width: 600px) {
        .form-grid

    {
        grid-template-columns: 1fr;
    }

    }
</style>
<script>
    
    let paymentDone = false;

    // لما يبدأ الدفع (اختياري)
    function startPayment() {
        localStorage.setItem("paymentStatus", "pending");
    }

    // لما الدفع ينجح (هتستدعيها بعد الرجوع من صفحة الدفع)
    function paymentSuccess() {
        paymentDone = true;
        localStorage.setItem("paymentStatus", "paid");

        document.getElementById("submitBtn").disabled = false;
        document.getElementById("submitBtn").classList.add("active");
    }

    // عند تحميل الصفحة
    window.onload = function () {
        if (localStorage.getItem("paymentStatus") === "paid") {
            paymentSuccess();
        }
    };

    // منع submit لو مفيش دفع
    document.getElementById("submitBtn").addEventListener("click", function (e) {
        if (!paymentDone) {
            e.preventDefault();
            alert("⚠️ You must complete payment first!");
        }
    });

    const listingType = document.getElementById("listingType");
    const rentDiv = document.getElementById("rentPeriodContainer");
    const rentSelect = document.getElementById("rentPeriod");

    function toggleRent() {
        let value = listingType.value;

        // لو enum بيبعت أرقام: Sale = 0 ، Rent = 1
        if (value == "0" || value === "Sale") {
            rentDiv.style.display = "none";
            rentSelect.value = ""; // reset
        }
        else if (value == "1" || value === "Rent") {
            rentDiv.style.display = "block";
        }
        else {
            rentDiv.style.display = "none";
            rentSelect.value = "";
        }
    }

    // أول ما الصفحة تفتح
    document.addEventListener("DOMContentLoaded", function () {
        toggleRent();
    });

    // لما المستخدم يغير
    listingType.addEventListener("change", toggleRent);
</script>