@model Listing

<div class="details-card">

    <h3>👁 Listing Details</h3>

    <div class="details-grid">

        <div class="detail-item">
            <label>Unit Number</label>
            <span>@Model.Unit?.UnitNumber</span>
        </div>

        <div class="detail-item">
            <label>City</label>
            <span>@Model.Unit?.Property?.City</span>
        </div>

        <div class="detail-item">
            <label>Location</label>
            <span>@Model.Unit?.Property?.Location</span>
        </div>

        <div class="detail-item">
            <label>Listing Type</label>
            <span>@Model.listingType</span>
        </div>

        <div class="detail-item">
            <label>Price</label>
            <span>@Model.Unit?.Price.ToString("C")</span>
        </div>

        <div class="detail-item">
            <label>Broker %</label>
            <span>@(Model.BrokerPercentage ?? 0) %</span>
        </div>

        <div class="detail-item">
            <label>Rent Period</label>
            <span>@(Model.Rentperiod?.ToString() ?? "N/A")</span>
        </div>

        <div class="detail-item">
            <label>Area Size</label>
            <span>@Model.Unit?.AreaSize m²</span>
        </div>

        <div class="detail-item">
            <label>Purpose</label>
            <span>@Model.Unit?.Purpose</span>
        </div>
        
        <div class="detail-item">
                <label>Type</label>
                <span>@Model.Unit?.type</span>
        </div>
        
        <div class="detail-item">
                <label>Description</label>
                <span>@Model.Unit?.Description</span>
        </div>

        <div class="detail-item">
            <label>Status</label>
            @if (Model.IsActive)
            {
                <span class="status-badge active">Active</span>
            }
            else
            {
                <span class="status-badge inactive">Inactive</span>
            }
        </div>

        <div class="detail-item">
            <label>Created At</label>
            <span>@Model.createAt.ToString("g")</span>
        </div>

    </div>

    <!-- Description -->
    <div class="description-box">
        <label>Description</label>
        <p>@Model.Description</p>
    </div>

    <!-- Buttons -->
    <div class="details-actions">
        <a href="/Admin/Listing/Edit/@Model.Id" class="btn-edit">✏ Edit</a>
        <a href="/Admin/Listing/ALLlisting" class="btn-back">⬅ Back</a>
    </div>

</div>
<style>
            /* 🔳 Card */
            .details-card {
                background: #1e1e2f;
                padding: 25px;
                border-radius: 16px;
                color: white;
                max-width: 1100px;
                margin: 30px auto;
                box-shadow: 0 10px 25px rgba(0,0,0,0.3);
            }

                /* 🧠 Title */
                .details-card h3 {
                    margin-bottom: 25px;
                    font-size: 22px;
                    font-weight: bold;
                }

            /* 🔲 Grid */
            .details-grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 15px;
            }

            /* 📦 Item */
            .detail-item {
                background: #2b2b3d;
                padding: 15px;
                border-radius: 10px;
                transition: 0.3s;
                border: 1px solid transparent;
            }

                .detail-item:hover {
                    transform: translateY(-3px);
                    border: 1px solid #28a745;
                }

                /* 🔤 Label */
                .detail-item label {
                    display: block;
                    font-size: 12px;
                    color: #aaa;
                    margin-bottom: 5px;
                }

                /* 🔢 Value */
                .detail-item span {
                    font-size: 16px;
                    font-weight: bold;
                    color: #fff;
                }

            /* 🟢 Status */
            .status-badge {
                padding: 5px 12px;
                border-radius: 20px;
                font-size: 12px;
                font-weight: bold;
            }

                .status-badge.active {
                    background: #28a745;
                }

                .status-badge.inactive {
                    background: #dc3545;
                }

            /* 📝 Description */
            .description-box {
                margin-top: 25px;
                background: #2b2b3d;
                padding: 15px;
                border-radius: 10px;
                border-left: 4px solid #007bff;
            }

                .description-box label {
                    display: block;
                    color: #aaa;
                    margin-bottom: 8px;
                }

                .description-box p {
                    margin: 0;
                    line-height: 1.6;
                }

            /* 🔘 Buttons */
            .details-actions {
                margin-top: 25px;
                display: flex;
                gap: 10px;
            }

            /* ✏ Edit */
            .btn-edit {
                flex: 1;
                background: #ffc107;
                color: black;
                padding: 12px;
                text-align: center;
                border-radius: 10px;
                text-decoration: none;
                font-weight: bold;
                transition: 0.3s;
            }

                .btn-edit:hover {
                    background: #e0a800;
                    transform: scale(1.02);
                }

            /* ⬅ Back */
            .btn-back {
                flex: 1;
                background: #6c757d;
                color: white;
                padding: 12px;
                text-align: center;
                border-radius: 10px;
                text-decoration: none;
                font-weight: bold;
                transition: 0.3s;
            }

                .btn-back:hover {
                    background: #5a6268;
                    transform: scale(1.02);
                }

            /* 📱 Responsive */
             (max-width: 992px) {
                .details-grid

            {
                grid-template-columns: repeat(2, 1fr);
            }

            }

             (max-width: 600px) {
                .details-grid

            {
                grid-template-columns: 1fr;
            }

            .details-actions {
                flex-direction: column;
            }

            }
</style>