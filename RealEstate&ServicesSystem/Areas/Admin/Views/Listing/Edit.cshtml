@using RealEstate_ServicesSystem.Viewmodel
@model EditListingmodel

<div class="form-card">
    <h3>✏ Edit Listing</h3>

    <form method="post">

        <!-- مهم جدًا -->
        <input type="hidden" asp-for="Id" />

        <div class="form-grid">

            <!-- Unit -->
            <div class="d-flex align-items-center gap-2">
                <label class="mb-0">UnitId</label>
                <select asp-for="UnitId" class="form-select w-auto">
                    @foreach (var u in Model.Units)
                    {
                        @if (u.Id == Model.UnitId)
                        {
                            <option value="@u.Id" selected>@u.UnitNumber</option>
                        }
                        else
                        {
                            <option value="@u.Id">@u.UnitNumber</option>
                        }
                    }
                </select>
            </div>

            <!-- Broker Percentage -->
            <div class="d-flex align-items-center gap-2">
                <label class="mb-0">Broker%</label>
                <input asp-for="BrokerPercentage" class="form-control w-auto" placeholder="Broker %" />
                <span class="text-danger" asp-validation-for="BrokerPercentage"></span>
            </div>

            <!-- Rent Period -->
            @if (Model.Listing.Unit.Purpose == UnitPurpose.Rent)
            {
                <div id="rentPeriodContainer">
                    <select asp-for="Rentperiod"
                            asp-items="Html.GetEnumSelectList<RentPeriod>()">
                        <option value="">Rent Period</option>
                    </select>
                <span class="text-danger" asp-validation-for="Rentperiod"></span>
                </div>
            }else
            {
                
            }

            <!-- Status -->
            <select asp-for="IsActive">
                <option value="">Status</option>
                @if (Model.IsActive)
                {
                    <option value="true" selected>Active</option>
                    <option value="false">Inactive</option>
                }
                else
                {
                    <option value="true">Active</option>
                    <option value="false" selected>Inactive</option>
                }
            </select>

        </div>

        <!-- Description -->
        <textarea asp-for="Description" placeholder="Description" ></textarea>
        <span class="text-danger" asp-validation-for="Description"></span>

        <!-- Buttons -->
        <div class="form-actions">
            <button type="submit" class="submit-btn">💾 Update</button>

            <a href="/Admin/Listing/AllListing" class="back-btn">
                ⬅ Back
            </a>
        </div>

    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    /* 🔳 Card */
    .form-card {
        background: #1e1e2f;
        padding: 25px;
        border-radius: 12px;
        color: white;
        max-width: 1200px;
        margin: 20px auto;
    }

        /* Title */
        .form-card h3 {
            margin-bottom: 20px;
        }

    /* Grid */
    .form-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
    }

        /* Inputs */
        .form-grid input,
        .form-grid select {
            padding: 10px;
            border-radius: 8px;
            border: none;
            outline: none;
            background: #2b2b3d;
            color: white;
        }

    /* Textarea */
    textarea {
        width: 100%;
        margin-top: 15px;
        padding: 12px;
        border-radius: 8px;
        border: none;
        background: #2b2b3d;
        color: white;
    }

    /* Buttons */
    .form-actions {
        display: flex;
        gap: 10px;
        margin-top: 15px;
    }

    .submit-btn {
        flex: 1;
        padding: 12px;
        background: #28a745;
        border: none;
        border-radius: 10px;
        color: white;
        cursor: pointer;
    }

        .submit-btn:hover {
            background: #218838;
        }

    .back-btn {
        flex: 1;
        padding: 12px;
        background: #6c757d;
        border-radius: 10px;
        color: white;
        text-align: center;
        text-decoration: none;
    }

        .back-btn:hover {
            background: #5a6268;
        }

    /* 📱 Responsive */
     (max-width: 768px) {
        .form-grid

    {
        grid-template-columns: 1fr;
    }

    }
</style>