@model RealEstate_ServicesSystem.Viewmodel.ViewRequests


@section Scripts {

    @if (TempData["success"] != null)
    {
        <script>
              toastr.options = {
                  "closeButton": false,
                  "debug": false,
                  "newestOnTop": false,
                  "progressBar": true,
                  "positionClass": "toast-top-center",
                  "preventDuplicates": false,
                  "onclick": null,
                  "showDuration": "300",
                  "hideDuration": "1000",
                  "timeOut": "5000",
                  "extendedTimeOut": "1000",
                  "showEasing": "swing",
                  "hideEasing": "linear",
                  "showMethod": "fadeIn",
                  "hideMethod": "fadeOut"
                }

            toastr.success('@TempData["success"]');

        </script>
    }
    @if (@TempData["error"] != null)
    {
        <script>
                  toastr.options = {
                      "closeButton": false,
                      "debug": false,
                      "newestOnTop": false,
                      "progressBar": true,
                      "positionClass": "toast-top-center",
                      "preventDuplicates": false,
                      "onclick": null,
                      "showDuration": "300",
                      "hideDuration": "1000",
                      "timeOut": "5000",
                      "extendedTimeOut": "1000",
                      "showEasing": "swing",
                      "hideEasing": "linear",
                      "showMethod": "fadeIn",
                      "hideMethod": "fadeOut"
                                }
            toastr.error('@TempData["error"]');
        </script>
    }
}

<div class="table-container">
    <h1>User Requests</h1>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>Request Type</th>
                <th>Message</th>
                <th>Listing Description</th>
                <th>Unit Description</th>
                <th>Unit Number</th>
                <th>City</th>
                <th>Location</th>
                <th>Address</th>
                <th>CreateAt</th>
                <th>From</th>
                <th>to</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var request in Model.Userrequest)
            {
                <tr>
                    <td>@request.Id</td>
                    <td>@request.RequestType</td>
                    <td>@request.msg</td>
                    <td>@request.Listing.Description</td>
                    <td>@request.Listing.Unit.Description</td>
                    <td>@request.Listing.Unit.UnitNumber</td>
                    <td>@request.Listing.Unit.Property.City</td>
                    <td>@request.Listing.Unit.Property.Location</td>
                    <td>@request.Listing.Unit.Property.Address</td>
                    <td>@request.ReuquestAt</td>
                    <td>@request.Listing.ApplicationUser.Email</td>
                    <td>@request.Listing.Unit.Property.Applicationuser.Email</td>
                </tr>
            }
        </tbody>
    </table>
</div>

                    <style>
    /* ===== Table Container ===== */
    .table {
        width: 100%;
        border-collapse: collapse;
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        transition: 0.3s;
    }

        /* Table Header */
        .table thead {
            background: linear-gradient(45deg, #0d6efd, #6610f2);
            color: white;
        }

            .table thead th {
                padding: 14px;
                font-size: 14px;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

        /* Table Body */
        .table tbody td {
            padding: 12px;
            font-size: 14px;
            color: #333;
            border-bottom: 1px solid #eee;
        }

        /* Row Hover Effect */
        .table tbody tr {
            transition: all 0.3s ease;
        }

            .table tbody tr:hover {
                background: rgba(13,110,253,0.06);
                transform: scale(1.01);
            }

            /* Zebra effect (optional) */
            .table tbody tr:nth-child(even) {
                background: #fafafa;
            }

    /* Title */
    h1 {
        font-weight: bold;
        margin-bottom: 15px;
        color: #333;
    }

    /* Responsive */
     (max-width: 768px) {
        .table

    {
        font-size: 12px;
    }

    .table thead th,
    .table tbody td {
        padding: 8px;
    }

    }
                    </style>