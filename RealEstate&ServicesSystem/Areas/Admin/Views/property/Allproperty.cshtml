@using RealEstate_ServicesSystem.Utilities.DBinitializer
@model IEnumerable<RealEstate_ServicesSystem.Models.Property>

@section Scripts {

    @if (TempData["success"] != null)
    {
        <script>
              toastr.options = {
                  "closeButton": false,
                  "debug": false,
                  "newestOnTop": false,
                  "progressBar": true,
                  "positionClass": "toast-top-center",
                  "preventDuplicates": false,
                  "onclick": null,
                  "showDuration": "300",
                  "hideDuration": "1000",
                  "timeOut": "5000",
                  "extendedTimeOut": "1000",
                  "showEasing": "swing",
                  "hideEasing": "linear",
                  "showMethod": "fadeIn",
                  "hideMethod": "fadeOut"
                }

            toastr.success('@TempData["success"]');

        </script>
    }
    @if (@TempData["error"] != null)
    {
        <script>
                  toastr.options = {
                      "closeButton": false,
                      "debug": false,
                      "newestOnTop": false,
                      "progressBar": true,
                      "positionClass": "toast-top-center",
                      "preventDuplicates": false,
                      "onclick": null,
                      "showDuration": "300",
                      "hideDuration": "1000",
                      "timeOut": "5000",
                      "extendedTimeOut": "1000",
                      "showEasing": "swing",
                      "hideEasing": "linear",
                      "showMethod": "fadeIn",
                      "hideMethod": "fadeOut"
                                }
            toastr.error('@TempData["error"]');
        </script>
    }
}


@if(User.IsInRole(DS.Role_Admin) || User.IsInRole(DS.Role_Employee) )
{
<div class="container-fluid">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="text-white">🏠 Properties</h3>
        <a href="/Admin/Property/Add" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add Property
        </a>
    </div>

    <div class="filter-card">

        <button class="filter-toggle" onclick="toggleFilter()">
            🔍 Filter Properties
        </button>

        <form id="filterForm" class="filter-form" method="get">

            <div class="filter-grid">

                <input type="text" name="city" placeholder="City" value="@ViewBag.city" />

                <input type="text" name="location" placeholder="Location" value="@ViewBag.location" />

                @* <select name="status">
                    <option value="">All Status</option>
                    @if(ViewBag.status == true)
                    {
                        <option value="true" selected>Available</option>
                        <option value="false">Not Available</option>
                    }else
                    {
                        <option value="true">Available</option>
                        <option value="false" selected>Not Available</option>
                    }
                </select> *@
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" id="status4">
                    <label class="form-check-label" for="status4">
                        Available
                    </label>
                </div>

                <button type="submit" class="apply-btn">
                    Apply Filter
                </button>

            </div>

        </form>

    </div>

    <!-- TABLE -->
    <div class="table-responsive">
        <table class="table table-dark table-hover align-middle rounded overflow-hidden">

            <thead class="table-secondary text-dark">
                <tr>
                    <th>City</th>
                    <th>Location</th>
                    <th>Address</th>
                    <th>Description</th>
                    <th>Created</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var property in Model)
                {
                    <tr>
                        <td>
                            <span class="badge bg-info text-dark">
                                @property.City
                            </span>
                        </td>

                        <td>@property.Location</td>

                        <td>@property.Address</td>

                        <td class="text-truncate" style="max-width:200px;">
                            @property.Description
                        </td>

                        <td>
                            @property.CreatedAt.ToString("yyyy-MM-dd")
                        </td>
                        <td>
                            @if (property.IsAvailable)
                            {
                                <span class="badge bg-success">Available</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Not Available</span>
                            }
                        </td>
                        <td class="text-center">
                            <a href="/Admin/Property/Details/@property.Id" class="btn btn-sm btn-info">
                                <i class="bi bi-eye"></i>
                            </a>

                            <a href="/Admin/Property/Edit/@property.Id" class="btn btn-sm btn-warning">
                                <i class="bi bi-pencil"></i>
                            </a>

                            <form asp-action="Delete" asp-route-id="@property.Id" method="post"
                                  style="display:inline;"
                                  onsubmit="return confirm('هل أنت متأكد من حذف الوحدة؟');">

                                <button type="submit" class="btn btn-danger btn-sm">
                                    Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>

        </table>
        <div class="pagination">

            <a href="?page=1" class="page-btn">First</a>
            @if (ViewBag.cureentpage > 1)
            {
            <a href="?page=@(ViewBag.cureentpage - 1)" class="page-btn">
                Prev
            </a>
            }

            @for (int i = 1; i <= @ViewBag.totalpage; i++)
            {
                <a href="?page=@i"
                   class="page-btn @(i == ViewBag.cureentpage ? "active" : "")">
                    @i
                </a>
            }
            @if (ViewBag.cureentpage < ViewBag.totalpage)
            {
                <a href="?page=@(ViewBag.cureentpage + 1)" class="page-btn">
                    Next
                </a>
            }

            <a href="?page=@ViewBag.totalpage" class="page-btn">
                Last
            </a>

        </div>
    </div>

    </div>
}else
{
    <p class="success-message">✔ The operation successfully</p>

    <style>
    .success-message {
    background: rgba(34, 197, 94, 0.15);
    color: #22c55e;
    padding: 12px 18px;
        border-radius: 10px;
    border: 1px solid rgba(34, 197, 94, 0.4);
        font-weight: 500;
    width: fit-content;
    margin: 10px auto;
    animation: fadeIn 0.4s ease;
    }
    </style>

    <script>
        setTimeout(() =>
        {
            const msg = document.querySelector(".success-message");
            if (msg)
            {
                msg.style.transition = "0.5s";
                msg.style.opacity = "0";
                setTimeout(() => msg.remove(), 500);
            }
        }, 3000);
    </script>
    
}


   <style>
    /* 🔳 Table Wrapper */
    .table-responsive {
        background: #1e1e2f;
        padding: 15px;
        border-radius: 12px;
        margin: 20px auto;
    }

    /* 📊 Table */
    .custom-table {
        width: 100%;
        border-collapse: collapse;
        color: white;
    }

        /* 🔝 Header */
        .custom-table thead {
            background: #f8f9fa;
            color: #000;
        }

        .custom-table th {
            padding: 12px;
            text-align: center;
            font-weight: bold;
        }

        /* 📄 Rows */
        .custom-table tbody tr {
            background: #2b2b3d;
            transition: 0.3s;
        }

            .custom-table tbody tr:hover {
                background: #3a3a55;
                transform: translateY(-2px);
            }

        /* Cells */
        .custom-table td {
            padding: 10px;
            text-align: center;
            border-bottom: 1px solid #444;
        }

        /* 🎯 Buttons */
        .custom-table .btn {
            border-radius: 8px;
            margin: 2px;
            transition: 0.3s;
        }

            .custom-table .btn:hover {
                transform: scale(1.05);
            }

    /* 🟢 Status Badge (نفس ستايلك) */
    .status-badge {
        padding: 5px 10px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: bold;
    }

        .status-badge.active {
            background: #28a745;
        }

        .status-badge.inactive {
            background: #dc3545;
        }
    /* 🔳 Filter Card */
    .filter-card {
        background: #1e1e2f;
        padding: 15px;
        border-radius: 12px;
        color: white;
        width: 100%;
        max-width: 800px;
        margin: 20px auto;
    }

    /* 🔘 Toggle Button */
    .filter-toggle {
        width: 100%;
        padding: 12px;
        background: #28a745;
        border: none;
        color: white;
        font-size: 16px;
        border-radius: 10px;
        cursor: pointer;
        transition: 0.3s;
    }

        .filter-toggle:hover {
            background: #218838;
        }

    /* 📋 Form */
    .filter-form {
        margin-top: 15px;
        display: none; /* hidden by default */
    }

    /* 🔲 Grid */
    .filter-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 10px;
    }

        /* Inputs */
        .filter-grid input,
        .filter-grid select {
            padding: 10px;
            border-radius: 8px;
            border: none;
            outline: none;
            background: #2b2b3d;
            color: white;
        }

            .filter-grid input::placeholder {
                color: #aaa;
            }

    /* 🔵 Apply Button */
    .apply-btn {
        grid-column: span 2;
        padding: 10px;
        background: #007bff;
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: 0.3s;
    }

        .apply-btn:hover {
            background: #0056b3;
        }

    /* 📱 Responsive */
     (max-width: 600px) {
        .filter-grid

    {
        grid-template-columns: 1fr;
    }

    .apply-btn {
        grid-column: span 1;
    }

    }
    /* 🔢 Pagination (نفس اللي عندك بالظبط) */
    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 6px;
        margin: 30px 0;
        flex-wrap: wrap;
    }

    .page-btn {
        padding: 8px 14px;
        background: #1e1e2f;
        color: white;
        border-radius: 8px;
        text-decoration: none;
        transition: 0.3s;
        border: 1px solid #333;
    }

        .page-btn:hover {
            background: #28a745;
            color: white;
            transform: translateY(-2px);
        }

        .page-btn.active {
            background: #007bff;
            color: white;
            font-weight: bold;
            pointer-events: none;
        }

    /* 📱 Responsive */
      (max-width: 600px) {
        .custom-table th, .custom-table td

    {
        font-size: 12px;
        padding: 6px;
    }

    }
    
        </style>

<script>
        function toggleFilter() {
        const form = document.getElementById("filterForm");

        if (form.style.display === "block") {
            form.style.display = "none";
        } else {
            form.style.display = "block";
        }
    }
    window.onload = function () {
    const toast = document.getElementById("toast");

    if (toast) {
        setTimeout(() => {
            toast.classList.remove("show-toast");
            toast.classList.add("hide-toast");
        }, 3000);
    }
}

function closeToast() {
    const toast = document.getElementById("toast");
    toast.classList.remove("show-toast");
    toast.classList.add("hide-toast");
}
</script>