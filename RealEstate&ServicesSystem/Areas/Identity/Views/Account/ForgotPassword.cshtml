@model RealEstate_ServicesSystem.Viewmodel.ForgetpasswordVM


@{
    ViewData["Title"] = " Forgot Password";
}
<style>
    /* Modern Glassmorphism & Gradient Design */
    :root {
        --primary-color: #4f46e5;
        --primary-hover: #4338ca;
        --bg-gradient-1: #0f172a;
        --bg-gradient-2: #1e1b4b;
        --text-main: #f8fafc;
        --text-muted: #94a3b8;
        --glass-bg: rgba(30, 41, 59, 0.7);
        --glass-border: rgba(255, 255, 255, 0.1);
        --input-bg: rgba(15, 23, 42, 0.6);
    }

    body {
        margin: 0;
        font-family: 'Inter', 'Tajawal', sans-serif;
        background: linear-gradient(135deg, var(--bg-gradient-1), var(--bg-gradient-2));
        color: var(--text-main);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow-x: hidden;
    }
    /* Animated background elements */
    .bg-shape {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        z-index: -1;
        animation: float 10s infinite alternate ease-in-out;
    }

    .shape-1 {
        width: 400px;
        height: 400px;
        background: rgba(79, 70, 229, 0.3);
        top: -100px;
        left: -100px;
    }

    .shape-2 {
        width: 300px;
        height: 300px;
        background: rgba(236, 72, 153, 0.2);
        bottom: -50px;
        right: -50px;
        animation-delay: -5s;
    }
    @@keyframes float {
        0% { transform: translateY(0) scale(1); }
        100% { transform: translateY(-30px) scale(1.1); }
    }
    /* Container & Card */
    .auth-container {
        width: 100%;
        max-width: 450px;
        padding: 2rem;
        position: relative;
        z-index: 1;
    }

    .glass-card {
        background: var(--glass-bg);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid var(--glass-border);
        border-radius: 24px;
        padding: 3rem 2.5rem;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        text-align: center;
        animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(40px); }
        to { opacity: 1; transform: translateY(0); }
    }
    /* Typography */
    .glass-card h4 {
        font-size: 1.75rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        background: linear-gradient(to right, #fff, #a5b4fc);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .glass-card p.subtitle {
        color: var(--text-muted);
        font-size: 0.95rem;
        margin-bottom: 2rem;
        line-height: 1.5;
    }
    /* Form Styles */
    .form-group {
        margin-bottom: 1.5rem;
        text-align: right; /* RTL support for Arabic */
        position: relative;
    }

    .form-control {
        width: 100%;
        background: var(--input-bg);
        border: 1px solid var(--glass-border);
        color: #fff;
        padding: 1rem 1.25rem;
        border-radius: 12px;
        font-size: 1rem;
        transition: all 0.3s ease;
        box-sizing: border-box;
    }

        .form-control:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.2);
            background: rgba(15, 23, 42, 0.8);
        }

    .control-label {
        display: block;
        font-size: 0.9rem;
        font-weight: 500;
        margin-bottom: 0.5rem;
        color: #cbd5e1;
    }
    /* Button */
    .btn-primary {
        width: 100%;
        background: var(--primary-color);
        color: white;
        border: none;
        padding: 1rem;
        border-radius: 12px;
        font-size: 1.1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: 1rem;
        box-shadow: 0 4px 6px -1px rgba(79, 70, 229, 0.4);
    }

        .btn-primary:hover {
            background: var(--primary-hover);
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(79, 70, 229, 0.5);
        }

        .btn-primary:active {
            transform: translateY(0);
        }
    /* Links */
    .back-link {
        display: inline-block;
        margin-top: 1.5rem;
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.9rem;
        transition: color 0.3s ease;
    }

        .back-link:hover {
            color: #fff;
        }
    /* Validation */
    .text-danger {
        color: #ef4444;
        font-size: 0.85rem;
        margin-top: 0.25rem;
        display: block;
        text-align: right;
    }

    .validation-summary-errors {
        background: rgba(239, 68, 68, 0.1);
        border-left: 4px solid #ef4444;
        padding: 1rem;
        border-radius: 8px;
        margin-bottom: 1.5rem;
        text-align: right;
    }

        .validation-summary-errors ul {
            margin: 0;
            padding-left: 1.5rem;
            padding-right: 1.5rem;
        }
</style>
<div class="bg-shape shape-1"></div>
<div class="bg-shape shape-2"></div>
<div class="auth-container" dir="rtl">
    <div class="glass-card">
        <!-- Icon/Logo Placeholder (Key Icon for Password Reset) -->
        <div style="width: 64px; height: 64px; background: rgba(79, 70, 229, 0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem auto;">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--primary-color)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 18v3c0 .6.4 1 1 1h4v-3h3v-3h2l1.4-1.4a6.5 6.5 0 1 0-4-4Z"></path>
                <circle cx="16.5" cy="7.5" r=".5" fill="currentColor"></circle>
            </svg>
        </div>
        <h4>نسيت كلمة المرور</h4>
        <p class="subtitle">أدخل بريدك الإلكتروني وسنقوم بإرسال رابط لتغيير كلمة المرور الخاصة بك.</p>
        <form asp-action="ForgotPassword" id="forgotForm">
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors text-danger"></div>

            <div class="form-group">
                <label asp-for="Email" class="control-label">البريد الإلكتروني</label>
                <input asp-for="Email" class="form-control" placeholder="example@domain.com" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary" id="submitBtn">
                    <span class="btn-text">إرسال رابط استعادة كلمة المرور</span>
                    <!-- Loading spinner (hidden by default) -->
                    <span class="spinner" style="display: none;">
                        <svg style="animation: spin 1s linear infinite; width: 1.25rem; height: 1.25rem; margin: 0 auto;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle style="opacity: 0.25;" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path style="opacity: 0.75;" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                    </span>
                </button>
            </div>
        </form>
        <div>
            <a asp-action="Login" class="back-link">
                &rarr; العودة لتسجيل الدخول
            </a>
        </div>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Add a smooth loading state to the button upon submission
        document.getElementById('forgotForm').addEventListener('submit', function(e) {
            // Check if form is valid before showing loader
            if ($(this).valid()) {
                const btn = document.getElementById('submitBtn');
                const btnText = btn.querySelector('.btn-text');
                const spinner = btn.querySelector('.spinner');

                btnText.style.display = 'none';
                spinner.style.display = 'block';
                btn.style.opacity = '0.8';
                btn.style.cursor = 'not-allowed';
            }
        });
    </script>

    <style>
        @@keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
    </style>
}