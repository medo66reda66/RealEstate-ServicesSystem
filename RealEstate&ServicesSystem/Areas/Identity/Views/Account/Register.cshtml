@model RealEstate_ServicesSystem.Viewmodel.RegisterVM

<div class="page">
    <div class="card">

        <h2>Create Account</h2>

        <form asp-action="Register" method="post">

            <div asp-validation-summary="ModelOnly" class="error"></div>

            <div class="input-box">
                <input asp-for="FullName" required />
                <label>Full Name</label>
                <span asp-validation-for="FullName"></span>
            </div>

            <div class="input-box">
                <input asp-for="Email" required />
                <label>Email</label>
                <span asp-validation-for="Email"></span>
            </div>

            <div class="input-box">
                <input asp-for="PhoneNumber" required />
                <label>Phone Number</label>
                <span asp-validation-for="PhoneNumber"></span>
            </div>

            <div class="input-box">
                <input asp-for="Address" required />
                <label>Address</label>
                <span asp-validation-for="Address"></span>
            </div>

            <div class="input-box password-box">
                <input asp-for="Password" type="password" id="pass" required />
                <label>Password</label>
                <i class="toggle" onclick="togglePassword()">👁️</i>
                <span asp-validation-for="Password"></span>
            </div>

            <div class="input-box">
                <input asp-for="ConfirmPassword" type="password" required />
                <label>Confirm Password</label>
                <span asp-validation-for="ConfirmPassword"></span>
            </div>
            <div class="input-box select-box">
                <select asp-for="Role" required>
                    <option value="" disabled selected hidden></option>
                    <option value="Agent">وكيل عقارات</option>
                    <option value="Owner">مالك</option>
                    <option value="User">مستخدم</option>
                </select>
                <label>Role</label>
                <span asp-validation-for="Role"></span>
            </div>

            <button type="submit">Create Account</button>

        </form>
        <partial name="_ExternalAuthenticationPartial" />
        <a href="/Identity/Account/Login" class="login-link">Already have account? Login</a>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
    }

    /* Center */
    .page {
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    /* Card */
    .card {
        width: 380px;
        padding: 40px;
        background: rgba(255,255,255,0.08);
        border-radius: 15px;
        backdrop-filter: blur(15px);
        box-shadow: 0 15px 40px rgba(0,0,0,0.4);
        animation: fadeIn 1s ease;
    }

    fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(30px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .card h2 {
        text-align: center;
        color: #fff;
        margin-bottom: 25px;
    }

    /* Inputs */
    .input-box {
        position: relative;
        margin-bottom: 20px;
    }

        .input-box input {
            width: 100%;
            padding: 12px;
            border: none;
            outline: none;
            border-radius: 8px;
            background: rgba(255,255,255,0.15);
            color: white;
        }

        .input-box label {
            position: absolute;
            top: 12px;
            left: 12px;
            color: #ddd;
            font-size: 14px;
            transition: 0.3s;
        }

        /* Floating label */
        .input-box input:focus + label,
        .input-box input:valid + label {
            top: -8px;
            left: 8px;
            font-size: 12px;
            background: #2c5364;
            padding: 2px 6px;
            border-radius: 4px;
        }

    /* Password eye */
    .password-box {
        position: relative;
    }

    .toggle {
        position: absolute;
        right: 10px;
        top: 12px;
        cursor: pointer;
    }

    /* Button */
    button {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 8px;
        background: #00c6ff;
        color: white;
        font-size: 16px;
        cursor: pointer;
        transition: 0.3s;
    }

        button:hover {
            background: #0072ff;
        }

    /* Link */
    .login-link {
        display: block;
        text-align: center;
        margin-top: 15px;
        color: #ccc;
        text-decoration: none;
    }

        .login-link:hover {
            color: white;
        }

    /* Errors */
    span {
        color: #ff6b6b;
        font-size: 12px;
    }

    .error {
        color: #ff6b6b;
        margin-bottom: 10px;
    }
    /* Select Styling */
    .select-box select {
        width: 100%;
        padding: 12px;
        border: none;
        outline: none;
        border-radius: 8px;
        background: rgba(255,255,255,0.15);
        color: black;
        appearance: none;
        cursor: pointer;
    }

    /* Arrow custom */
    .select-box::after {
        content: "▼";
        position: absolute;
        right: 12px;
        top: 14px;
        color: #ccc;
        pointer-events: none;
        font-size: 12px;
    }

    /* Floating label for select */
    .select-box select:focus + label,
    .select-box select:valid + label {
        top: -8px;
        left: 8px;
        font-size: 12px;
        background: #2c5364;
        padding: 2px 6px;
        border-radius: 4px;
    }
</style>

<script>
    function togglePassword() {
        var pass = document.getElementById("pass");
        pass.type = pass.type === "password" ? "text" : "password";
    }
</script>
