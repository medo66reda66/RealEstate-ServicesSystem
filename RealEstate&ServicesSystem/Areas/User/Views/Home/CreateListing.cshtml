@using RealEstate_ServicesSystem.Viewmodel
@model ListingUnitVM

<div class="container py-5">
    <!-- ================= FILTER TOGGLE ================= -->
    <br />
    <div class="mb-4 text-center">
        <button class="filter-toggle" onclick="toggleFilter()">
            🔍 Advanced Search (Filter Units)
        </button>
    </div>

    <!-- ================= FILTER BOX ================= -->
    <form method="get" class="filter-box mx-auto" id="filterBox" style="display:@(ViewBag.UnitNumber != null || ViewBag.Bedrooms != null || ViewBag.Bathrooms != null || ViewBag.AreaSize != null || ViewBag.FloorNumber != null || ViewBag.Price != null || ViewBag.Status != null || ViewBag.Purpose != null || ViewBag.Type != null ? "block" : "none")">
        <div class="filter-grid">
            <input type="number" name="unitNumber" placeholder="Unit Number" value="@ViewBag.UnitNumber" />
            <input type="number" name="bedrooms" placeholder="Bedrooms" value="@ViewBag.Bedrooms" />
            <input type="number" name="bathrooms" placeholder="Bathrooms" value="@ViewBag.Bathrooms" />
            <input type="number" name="areaSize" placeholder="Area Size (m²)" value="@ViewBag.AreaSize" />
            <input type="number" name="floorNumber" placeholder="Floor Number" value="@ViewBag.FloorNumber" />
            <input type="number" step="0.01" name="price" placeholder="Price" value="@ViewBag.Price" />
            
            <select name="status">
                <option value="">Status</option>
                <option value="Available" selected="@(ViewBag.Status?.ToString() == "Available")">Available</option>
                <option value="Sold" selected="@(ViewBag.Status?.ToString() == "Sold")">Sold</option>
                <option value="Rented" selected="@(ViewBag.Status?.ToString() == "Rented")">Rented</option>
            </select>

            <select name="purpose">
                <option value="">Purpose</option>
                <option value="Sale" selected="@(ViewBag.Purpose?.ToString() == "Sale")">Sale</option>
                <option value="Rent" selected="@(ViewBag.Purpose?.ToString() == "Rent")">Rent</option>
            </select>

            <select name="type">
                <option value="">Type</option>
                <option value="Apartment" selected="@(ViewBag.Type?.ToString() == "Apartment")">Apartment</option>
                <option value="Villa" selected="@(ViewBag.Type?.ToString() == "Villa")">Villa</option>
                <option value="Office" selected="@(ViewBag.Type?.ToString() == "Office")">Office</option>
                <option value="Shop" selected="@(ViewBag.Type?.ToString() == "Shop")">Shop</option>
            </select>

            <button type="submit" class="search-btn">Search 🔍</button>
        </div>
    </form>


    <!-- ================= ALL UNITS ================= -->
    <div class="d-flex justify-content-between align-items-center mb-3 mt-5">
        <h3 class="section-title text-dark-emphasis mb-0">🏠 All Units</h3>
        <a href="/User/Home/MyListings" class="btn btn-primary fw-bold" style="border-radius: 30px; padding: 10px 20px;">
            📋 Go to My Listings
        </a>
    </div>
    
    <div class="grid">
        @if(Model.unit != null)
        {
            foreach (var unit in Model.unit)
            {
                <div class="card shadow-lg">
                    <div class="image-box">
                        <img src="~/UnitImages/@unit.ImageUrl" onerror="this.src='https://via.placeholder.com/300x200?text=No+Image'"/>
                        <span class="price">@unit.Price EGP</span>
                    </div>
                    <div class="content d-flex flex-column" style="flex: 1;">
                        <h4>Unit @unit.UnitNumber</h4>
                        <h8><strong>Phone Number:</strong> @unit.Property.Applicationuser.PhoneNumber</h8>
                        <p class="text-muted mb-2" style="font-size: 14px;">📍 @unit.Property?.Location | Purpose: @unit.Purpose</p>

                        <div class="info">
                            <span>🛏 @unit.Bedrooms</span>
                            <span>🛁 @unit.Bathrooms</span>
                            <span>📐 @unit.AreaSize m²</span>
                            <span>🏢 Floor @unit.FloorNumber</span>
                        </div>
                        
                        <!-- ================= SUB IMAGES ================= -->
                        @if (unit.UnitSupImgs != null && unit.UnitSupImgs.Any())
                        {
                            <div class="sup-images d-flex gap-2 mt-3 overflow-auto pb-2" style="max-width: 100%;">
                                @foreach(var supimg in unit.UnitSupImgs)
                                {
                                    <img src="~/UnitSupImages/@supimg.ImageUrl" class="shadow-sm" style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px; border: 2px solid rgba(255,255,255,0.2); transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'" />
                                }
                            </div>
                        }

                        <div class="action-buttons mt-auto">
                            <!-- Link goes to Admin Add Listing -->
                            <a href="/Admin/Listing/Add/@unit.Id" class="btn w-100 fw-bold" style="background: #198754; color: white;">➕ Create Listing</a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <!-- ================= PAGINATION ================= -->
    @if(ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
    {
        <div class="pagination">
            <!-- Previous -->
            @if (ViewBag.CurrentPage > 1)
            {
                <a class="page-btn" href="?page=@(ViewBag.CurrentPage - 1)&unitNumber=@ViewBag.UnitNumber&bedrooms=@ViewBag.Bedrooms&bathrooms=@ViewBag.Bathrooms&areaSize=@ViewBag.AreaSize&floorNumber=@ViewBag.FloorNumber&price=@ViewBag.Price&status=@ViewBag.Status&purpose=@ViewBag.Purpose&type=@ViewBag.Type">
                    ⬅
                </a>
            }

            <!-- Pages -->
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <a class="page-btn @(ViewBag.CurrentPage == i ? "active" : "")" href="?page=@i&unitNumber=@ViewBag.UnitNumber&bedrooms=@ViewBag.Bedrooms&bathrooms=@ViewBag.Bathrooms&areaSize=@ViewBag.AreaSize&floorNumber=@ViewBag.FloorNumber&price=@ViewBag.Price&status=@ViewBag.Status&purpose=@ViewBag.Purpose&type=@ViewBag.Type">
                    @i
                </a>
            }

            <!-- Next -->
            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
            {
                <a class="page-btn" href="?page=@(ViewBag.CurrentPage + 1)&unitNumber=@ViewBag.UnitNumber&bedrooms=@ViewBag.Bedrooms&bathrooms=@ViewBag.Bathrooms&areaSize=@ViewBag.AreaSize&floorNumber=@ViewBag.FloorNumber&price=@ViewBag.Price&status=@ViewBag.Status&purpose=@ViewBag.Purpose&type=@ViewBag.Type">
                    ➡
                </a>
            }
        </div>
    }

</div>

<style>
    /* BUTTON */
    .filter-toggle {
        padding: 12px 25px;
        background: linear-gradient(45deg,#00c6ff,#007bff);
        border: none;
        border-radius: 30px;
        color: white;
        cursor: pointer;
        font-size: 16px;
        transition: 0.3s;
    }

    .filter-toggle:hover {
        transform: scale(1.05);
    }

    /* FILTER BOX */
    .filter-box {
        margin-top: 15px;
        padding: 25px;
        border-radius: 20px;
        background: rgba(30, 41, 59, 0.7);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.1);
        width: 100%;
        max-width: 1000px;
        display: none;
        animation: slideDown 0.5s ease;
    }

    /* GRID */
    .filter-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
    }

    /* INPUT */
    .filter-grid input,
    .filter-grid select {
        padding: 12px;
        border-radius: 10px;
        border: 1px solid rgba(255,255,255,0.2);
        outline: none;
        background: rgba(15, 23, 42, 0.8);
        color: white;
        font-size: 14px;
    }
    .filter-grid input::placeholder {
        color: #adb5bd;
    }

    /* BUTTON */
    .search-btn {
        grid-column: span 3;
        padding: 14px;
        border-radius: 12px;
        border: none;
        background: linear-gradient(45deg,#ff512f,#dd2476);
        color: white;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
    }

    .search-btn:hover {
        transform: scale(1.02);
    }

    @@keyframes slideDown {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@media (max-width: 768px) {
        .filter-grid {
            grid-template-columns: 1fr;
        }
        .search-btn {
            grid-column: span 1;
        }
    }

    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        margin: 40px 0;
        flex-wrap: wrap;
    }

    /* BUTTON */
    .page-btn {
        padding: 10px 16px;
        border-radius: 10px;
        background: #1e1e2f;
        color: white;
        text-decoration: none;
        border: 1px solid rgba(255,255,255,0.1);
        transition: 0.3s;
        font-weight: 500;
    }

    .page-btn:hover {
        background: linear-gradient(45deg,#007bff,#00c6ff);
        transform: translateY(-3px);
        box-shadow: 0 8px 15px rgba(13,110,253,0.3);
        color: white;
    }

    /* ACTIVE */
    .page-btn.active {
        background: linear-gradient(45deg,#ff512f,#dd2476);
        color: white;
        font-weight: bold;
        pointer-events: none;
        transform: scale(1.1);
        border: none;
    }

</style>

<script>
    function toggleFilter() {
        const box = document.getElementById("filterBox");
        if (box.style.display === "none" || box.style.display === "") {
            box.style.display = "block";
            localStorage.setItem("createListingFilterOpen", "true");
        } else {
            box.style.display = "none";
            localStorage.setItem("createListingFilterOpen", "false");
        }
    }

    window.onload = function () {
        const saved = localStorage.getItem("createListingFilterOpen");
        if (saved === "true") {
            document.getElementById("filterBox").style.display = "block";
        }
    };

    function toggleDetails(btn) {
        const box = btn.nextElementSibling;
        if (box.style.display === "block" || box.style.display === "") {
            box.style.display = "none";
            btn.innerHTML = "More Info 🔽";
        } else {
            box.style.display = "block";
            btn.innerHTML = "Less Info 🔼";
        }
    }

    function confirmDeleteListing(e, id) {
        e.preventDefault();
        if (confirm("Delete this listing?")) {
            window.location.href = "/Admin/Listing/Delete/" + id;
        }
    }
</script>
