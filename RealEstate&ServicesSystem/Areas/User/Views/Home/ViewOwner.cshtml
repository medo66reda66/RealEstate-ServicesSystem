@using RealEstate_ServicesSystem.Viewmodel
@model ViewOwnerVM


@section Scripts {

    @if (TempData["success"] != null)
    {
        <script>
              toastr.options = {
                  "closeButton": false,
                  "debug": false,
                  "newestOnTop": false,
                  "progressBar": true,
                  "positionClass": "toast-top-center",
                  "preventDuplicates": false,
                  "onclick": null,
                  "showDuration": "300",
                  "hideDuration": "1000",
                  "timeOut": "5000",
                  "extendedTimeOut": "1000",
                  "showEasing": "swing",
                  "hideEasing": "linear",
                  "showMethod": "fadeIn",
                  "hideMethod": "fadeOut"
                }

            toastr.success('@TempData["success"]');

        </script>
    }
    @if (@TempData["error"] != null)
    {
        <script>
                  toastr.options = {
                      "closeButton": false,
                      "debug": false,
                      "newestOnTop": false,
                      "progressBar": true,
                      "positionClass": "toast-top-center",
                      "preventDuplicates": false,
                      "onclick": null,
                      "showDuration": "300",
                      "hideDuration": "1000",
                      "timeOut": "5000",
                      "extendedTimeOut": "1000",
                      "showEasing": "swing",
                      "hideEasing": "linear",
                      "showMethod": "fadeIn",
                      "hideMethod": "fadeOut"
                                }
            toastr.error('@TempData["error"]');
        </script>
    }
}

<div class="container py-5">
    <br />
    <!-- ================= UNITS ================= -->
    <h3 class="section-title mb-3">🏠 Units</h3>
    @if(Model.Property == null || !Model.Property.Any())
    {
        <div class="alert alert-warning">
            You need to add a property before adding units. 
        </div>
    }else
    {
    <div class="grid">

        <!-- ADD UNIT -->
        <div class="card" style="cursor: pointer; display: flex; flex-direction: column; align-items: center; justify-content: center; background: rgba(34,197,94,0.05); border: 2px dashed #198754;" onclick="window.location.href='/Admin/Unit/Add'">
            <div style="font-size: 50px; color: #198754;">➕</div>
            <h4 class="mt-3 text-success font-weight-bold">Add Unit</h4>
        </div>

        @foreach (var unit in Model.Unit)
        {
            <div class="card">
                <div class="image-box">
                    <img src="~/UnitImages/@unit.ImageUrl" onerror="this.src='https://via.placeholder.com/300x200?text=No+Image'"/>
                    <span class="price">@unit.Price EGP</span>
                </div>
                <div class="content d-flex flex-column" style="flex: 1;">
                    <h4>Unit @unit.UnitNumber</h4>
                    <p class="text-muted mb-2" style="font-size: 14px;">📍 Purpose: @unit.Purpose | Status: @unit.status</p>

                    <div class="info">
                        <span>🛏 @unit.Bedrooms</span>
                        <span>🛁 @unit.Bathrooms</span>
                        <span>📐 @unit.AreaSize m²</span>
                        <span>🏢 Floor @unit.FloorNumber</span>
                    </div>

                    <div class="action-buttons mt-auto">
                        <a href="/Admin/Unit/Edit/@unit.Id" class="btn" style="background: #0d6efd;">✏️ Edit</a>
                        <a href="/Admin/Unit/Delete/@unit.Id" onclick="confirmDeleteUnit(event, @unit.Id)" class="btn" style="background: #dc3545;">🗑 Delete</a>
                    </div>
                    
                    <button class="btn mt-2 w-100" style="background: #6c757d;" onclick="toggleDetails(this)">More Info 🔽</button>
                    
                    <div class="details" style="display:none; font-size: 13px; margin-top:10px;">
                        <p><strong>Description:</strong> @unit.Discription</p>
                        <p><strong>Created At:</strong> @unit.CreatedAt.ToShortDateString()</p>
                        @if (unit.UnitSupImgs != null && unit.UnitSupImgs.Any())
                        {
                            <div class="mt-2 d-flex gap-2 flex-wrap">
                                @foreach (var sup in unit.UnitSupImgs)
                                {
                                    <img src="~/UnitSupImages/@sup.ImageUrl" style="width: 50px; height: 50px; object-fit: cover; border-radius: 5px;" />
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

    </div>
    }
    <!-- ================= PROPERTIES ================= -->
    <h3 class="section-title mt-5 mb-3">🏢 Properties</h3>

    <div class="grid">

        <!-- ADD PROPERTY -->
        <div class="card" style="cursor: pointer; display: flex; flex-direction: column; align-items: center; justify-content: center; background: rgba(13,110,253,0.05); border: 2px dashed #0d6efd;" onclick="window.location.href='/Admin/Property/Add'">
            <div style="font-size: 50px; color: #0d6efd;">➕</div>
            <h4 class="mt-3 text-primary font-weight-bold">Add Property</h4>
        </div>

        @foreach (var property in Model.Property)
        {
            <div class="card">
                <div class="content h-100 d-flex flex-column">
                    <h4 class="mt-2">🏢 @property.City</h4>
                    <p class="text-muted mb-1" style="font-size: 14px;">📍 @property.Location</p>
                    <p class="text-muted" style="font-size: 14px;">🏠 @property.Address</p>

                    <div class="mt-auto">
                        <div class="action-buttons">
                            <a href="/Admin/Property/Edit/@property.Id" class="btn" style="background: #0d6efd;">✏️ Edit</a>
                            <a href="/Admin/Property/Delete/@property.Id" onclick="confirmDeleteProperty(event, @property.Id)" class="btn" style="background: #dc3545;">🗑 Delete</a>
                        </div>
                        
                        <button class="btn mt-2 w-100" style="background: #6c757d;" onclick="toggleDetails(this)">More Info 🔽</button>

                        <div class="details" style="display:none; font-size: 13px; margin-top:10px;">
                            <p><strong>Description:</strong> @property.Description</p>
                            <p><strong>Available:</strong> @(property.IsAvailable ? "Yes" : "No")</p>
                        </div>
                    </div>
                </div>
            </div>
        }

    </div>

</div>

<script>
    // toggle details
    function toggleDetails(btn) {
        const box = btn.nextElementSibling;
        
        if (box.style.display === "block" || box.style.display === "") {
            box.style.display = "none";
            btn.innerHTML = "More Info 🔽";
        } else {
            box.style.display = "block";
            btn.innerHTML = "Less Info 🔼";
        }
    }

    // delete unit
    function confirmDeleteUnit(e, id) {
        e.preventDefault();
        if (confirm("Delete this unit?")) {
            window.location.href = "/Admin/Unit/Delete/" + id;
        }
    }

    // delete property
    function confirmDeleteProperty(e, id) {
        e.preventDefault();
        if (confirm("Delete this property?")) {
            window.location.href = "/Admin/Property/Delete/" + id;
        }
    }
</script>