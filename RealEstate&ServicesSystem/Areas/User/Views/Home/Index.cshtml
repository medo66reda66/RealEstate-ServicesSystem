@using RealEstate_ServicesSystem.Utilities.DBinitializer
@model IEnumerable<Listing>
<!-- HERO -->
@section Scripts {

    @if (TempData["success"] != null)
    {
        <script>
              toastr.options = {
                  "closeButton": false,
                  "debug": false,
                  "newestOnTop": false,
                  "progressBar": true,
                  "positionClass": "toast-top-center",
                  "preventDuplicates": false,
                  "onclick": null,
                  "showDuration": "300",
                  "hideDuration": "1000",
                  "timeOut": "5000",
                  "extendedTimeOut": "1000",
                  "showEasing": "swing",
                  "hideEasing": "linear",
                  "showMethod": "fadeIn",
                  "hideMethod": "fadeOut"
                }

            toastr.success('@TempData["success"]');

        </script>
    }
}

<section class="hero">

    <div class="hero-overlay">

        <h1 class="hero-title">Find Your Dream Property</h1>
        <p class="hero-sub">Buy • Rent • Invest</p>

        <!-- زرار إظهار الفلتر -->
        <button class="filter-toggle" onclick="toggleFilter()">
            🔍 Advanced Search
        </button>

        <!-- FILTER -->
         <form method="get"class="filter-box" id="filterBox" style="display:@(ViewBag.HasFilter ? "block" : "none")">

            <div class="filter-grid">

                <input type="text" name="city"
                       placeholder="City"
                       value="@ViewBag.city" />

                <input type="text" name="Location"
                       placeholder="Location"
                       value="@ViewBag.Location" />

                <input type="number" name="MinPrice"
                       placeholder="Min Price"
                       value="@ViewBag.MinPrice" />

                <input type="number" name="MaxPrice"
                       placeholder="Max Price"
                       value="@ViewBag.MaxPrice" />

                <input type="number" name="MinArea"
                       placeholder="Min Area"
                       value="@ViewBag.MinArea" />

                <input type="number" name="MaxArea"
                       placeholder="Max Area"
                       value="@ViewBag.MaxArea" />

                <input type="number" name="Bedrooms"
                       placeholder="Bedrooms"
                       value="@ViewBag.Bedrooms" />

                <input type="number" name="Bathrooms"
                       placeholder="Bathrooms"
                       value="@ViewBag.Bathrooms" />

                <select name="UnitPurpose">
                    <option value="">Purpose</option>
                    <option value="Sale">Sale</option>
                    <option value="Rent">Rent</option>
                </select>

                <button type="submit" class="search-btn">Search </button>

            </div>

        </form>

    </div>

</section>

<!-- LISTINGS -->
<section class="container py-5">
    <h2 class="section-title">🔥 Featured Properties</h2>

    <div style="text-align:center; margin-bottom:20px; display: flex; justify-content: center; gap: 15px; flex-wrap: wrap;">
        @if (User.IsInRole(DS.Role_Admin) || User.IsInRole(DS.Role_Employee) || User.IsInRole(DS.Role_Owner))
        {
            <a href="/User/Home/ViewOwner" class="page-btn">
                ⚙️ Manage Units
            </a>
        }
        @if (User.IsInRole(DS.Role_Admin) || User.IsInRole(DS.Role_Employee) || User.IsInRole(DS.Role_Agent))
        {
            <a href="/User/Home/CreateListing" class="page-btn" style="background: linear-gradient(45deg, #198754, #20c997); border-color: #198754;">
                📋 Manage Listings
            </a>
        }
    </div>
    <div class="grid">

        @foreach (var listing in Model)
        {
            <div class="card">

                <div class="image-box">
                    <img src="~/UnitImages/@listing.Unit.ImageUrl" />

                    <span class="price">@listing.Unit.Price EGP</span>

                    <button class="fav" onclick="toggleFav(@listing.Id, this)">
                     ❤
                    </button>
                </div>

                <div class="content">
                    <h4>@listing.Unit.UnitNumber</h4>

                    <p>📍 @listing.Unit.Property.City - @listing.Unit.Property.Location</p>
                    <h11>@listing.Unit.Property.Address - @listing.Unit.type</h11>

                    <div class="info">
                        <span>🛏 @listing.Unit.Bedrooms</span>
                        <span>📐 @listing.Unit.AreaSize m²</span>
                        <span>🏢 Floor @listing.Unit.FloorNumber</span>
                    </div>
                    <div class="action-buttons">

                        <a href="/user/Home/Details/@listing.Id" class="btn btn-outline-primary">
                            Details👁
                        </a>
                        @if (User.IsInRole(DS.Role_Admin) || User.IsInRole(DS.Role_User) || User.IsInRole(DS.Role_Employee))
                        {
                            if (User.Identity != null && User.Identity.IsAuthenticated)
                            {
                            <a href="/Admin/UserRequest/AddRequest/@listing.Id" class="btn btn-primary">
                                Request
                            </a>
                            }
                            else
                            {
                                <a href="/Identity/Account/Login" class="btn btn-primary">
                                    Login to Request
                                </a>
                            }
                        }
                    </div>
                </div>

             </div>
            
        }
    </div>
    <div class="pagination">

        <!-- Previous -->
        @if (ViewBag.currentpage > 1)
        {
            <a class="page-btn"
               href="?page=@(ViewBag.currentpage - 1)
               &city=@ViewBag.city
               &Location=@ViewBag.Location
               &MinPrice=@ViewBag.MinPrice
               &MaxPrice=@ViewBag.MaxPrice">
                ⬅
            </a>
        }

        <!-- Pages -->
        @for (int i = 1; i <= ViewBag.totalpages; i++)
        {
            <a class="page-btn @(ViewBag.currentpage == i ? "active" : "")"
               href="?page=@i
               &city=@ViewBag.city
               &Location=@ViewBag.Location
               &MinPrice=@ViewBag.MinPrice
               &MaxPrice=@ViewBag.MaxPrice">
                @i
            </a>
        }

        <!-- Next -->
        @if (ViewBag.currentpage < ViewBag.totalpages)
        {
            <a class="page-btn"
               href="?page=@(ViewBag.currentpage + 1)
               &city=@ViewBag.city
               &Location=@ViewBag.Location
               &MinPrice=@ViewBag.MinPrice
               &MaxPrice=@ViewBag.MaxPrice">
                ➡
            </a>
        }

    </div>
</section>
<style>
    /* HERO */
    .hero {
        height: 85vh;
        background: url('https://images.unsplash.com/photo-1560448204-e02f11c3d0e2') center/cover;
        position: relative;
    }

    .hero-overlay {
        height: 100%;
        background: linear-gradient(to bottom, rgba(0,0,0,0.4), rgba(0,0,0,0.8));
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        color: white;
        text-align: center;
    }

    /* TEXT */
    .hero-title {
        font-size: 55px;
        font-weight: 800;
        margin-bottom: 10px;
        animation: fadeUp 1s ease;
    }

    .hero-sub {
        font-size: 18px;
        margin-bottom: 20px;
    }

    /* BUTTON */
    .filter-toggle {
        padding: 12px 25px;
        background: linear-gradient(45deg,#00c6ff,#007bff);
        border: none;
        border-radius: 30px;
        color: white;
        cursor: pointer;
        font-size: 16px;
        transition: 0.3s;
    }

        .filter-toggle:hover {
            transform: scale(1.1);
        }

    /* FILTER BOX */
    .filter-box {
        margin-top: 20px;
        padding: 25px;
        border-radius: 20px;
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.2);
        width: 90%;
        max-width: 1000px;
        display: none;
        animation: slideDown 0.5s ease;
    }

    /* GRID */
    .filter-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
    }

        /* INPUT */
        .filter-grid input,
        .filter-grid select {
            padding: 12px;
            border-radius: 10px;
            border: none;
            outline: none;
            background: rgba(255,255,255,0.8);
            font-size: 14px;
        }

    /* BUTTON */
    .search-btn {
        grid-column: span 3;
        padding: 14px;
        border-radius: 12px;
        border: none;
        background: linear-gradient(45deg,#ff512f,#dd2476);
        color: white;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
    }

        .search-btn:hover {
            transform: scale(1.05);
        }

    /* ANIMATIONS */
     fadeUp {
        from

    {
        opacity: 0;
        transform: translateY(20px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    slideDown {
        from

    {
        opacity: 0;
        transform: translateY(-20px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    /* RESPONSIVE */
   @@media (max-width: 768px) {
        .filter-grid

    {
        grid-template-columns: 1fr;
    }

    .search-btn {
        grid-column: span 1;
    }

    }

    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        margin: 40px 0;
        flex-wrap: wrap;
    }

    /* BUTTON */
    .page-btn {
        padding: 10px 16px;
        border-radius: 10px;
        background: #1e1e2f;
        color: white;
        text-decoration: none;
        border: 1px solid #333;
        transition: 0.3s;
        font-weight: 500;
    }

        /* HOVER */
        .page-btn:hover {
            background: linear-gradient(45deg,#007bff,#00c6ff);
            transform: translateY(-3px);
            box-shadow: 0 8px 15px rgba(0,0,0,0.2);
        }

        /* ACTIVE */
        .page-btn.active {
            background: linear-gradient(45deg,#ff512f,#dd2476);
            color: white;
            font-weight: bold;
            pointer-events: none;
            transform: scale(1.1);
        }

        /* ARROWS */
        .page-btn:first-child,
        .page-btn:last-child {
            font-weight: bold;
        }
        /* =========================
   HERO RESPONSIVE
========================= */

@@media (max-width: 768px) {

    /* HERO */
    .hero {
        height: 60vh;
        padding: 15px;
    }

    .hero-title {
        font-size: 32px;
    }

    .hero-sub {
        font-size: 14px;
    }

    /* FILTER BOX */
    .filter-box {
        width: 95%;
        padding: 15px;
    }

    /* GRID */
    .filter-grid {
        grid-template-columns: 1fr;
        gap: 10px;
    }

    /* INPUTS */
    .filter-grid input,
    .filter-grid select {
        font-size: 13px;
        padding: 10px;
    }

    /* BUTTON */
    .search-btn {
        grid-column: span 1;
        padding: 12px;
        font-size: 14px;
    }

    /* BUTTON HERO */
    .filter-toggle {
        font-size: 14px;
        padding: 10px 18px;
    }

    /* PAGINATION */
    .page-btn {
        padding: 8px 12px;
        font-size: 13px;
    }
}

/* Small phones */
@@media (max-width: 480px) {

    .hero-title {
        font-size: 26px;
    }

    .hero-sub {
        font-size: 13px;
    }

    .filter-toggle {
        font-size: 13px;
    }
}
  /* =========================
   RESPONSIVE FIX (THIS PAGE)
========================= */

/* Tablets */

@@media (max-width: 992px) {

    .hero-title {
        font-size: 42px;
    }

    .hero-sub {
        font-size: 16px;
    }

    .filter-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .search-btn {
        grid-column: span 2;
    }
}


/* Mobile */
@@media (max-width: 768px) {

    /* HERO TEXT */
    .hero-title {
        font-size: 32px;
        padding: 0 10px;
    }

    .hero-sub {
        font-size: 14px;
    }

    /* FILTER */
    .filter-box {
        width: 95%;
        padding: 15px;
    }

    .filter-grid {
        grid-template-columns: 1fr;
    }

    .search-btn {
        grid-column: span 1;
    }

    /* LISTINGS GRID */
    .grid {
        justify-content: center;
    }

    .card {
        flex: 0 0 100%;
    }

    /* ACTION BUTTONS */
    .action-buttons {
        flex-direction: column;
    }

    .action-buttons .btn {
        width: 100%;
    }

    /* PAGINATION */
    .pagination {
        gap: 5px;
    }

    .page-btn {
        padding: 8px 12px;
        font-size: 13px;
    }
}

/* Small phones */
@@media (max-width: 576px) {

    .hero {
        height: 70vh;
    }

    .hero-title {
        font-size: 26px;
    }

    .filter-toggle {
        padding: 10px 18px;
        font-size: 14px;
    }

    .filter-box {
        padding: 12px;
    }

    .page-btn {
        padding: 7px 10px;
        font-size: 12px;
    }
}
</style>
<script>
 
    function toggleFav(listingId, btn) {

        fetch(`/User/Home/ToggleFavorite/${listingId}`, {
            method: 'POST'
        })
        .then(res => res.json())
        .then(data => {

            if (data.isFavorite) {
                btn.style.color = "red"; // متضاف
            } else {
                btn.style.color = "white"; // متشال
            }

        });
    }
    btn.innerHTML = data.isFavorite ? "❤️" : "🤍";

          function toggleFilter() {
        const box = document.getElementById("filterBox");

        if (box.style.display === "none" || box.style.display === "") {
            box.style.display = "block";
            localStorage.setItem("filterOpen", "true");
        } else {
            box.style.display = "none";
            localStorage.setItem("filterOpen", "false");
        }
    }

    // عند تحميل الصفحة
    window.onload = function () {
        const saved = localStorage.getItem("filterOpen");

        if (saved === "true") {
            document.getElementById("filterBox").style.display = "block";
        }
    };
        document.querySelectorAll(".page-btn").forEach(btn => {
        btn.addEventListener("click", function () {
            window.scrollTo({
                top: 0,
                behavior: "smooth"
            });
        });
    });
</script>