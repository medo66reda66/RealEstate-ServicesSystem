<script>
    var connection = new signalR.HubConnectionBuilder().withUrl("/notificationHub").build();

        connection.on("ReceiveNotification", function (message, url) {
            // Show toastr notification
            toastr.options = {
                "closeButton": true,
                "progressBar": true,
                "positionClass": "toast-top-right",
                "timeOut": "10000"
            };

            toastr.info(message, "🏠 New Listing Alert!", {
                onclick: function () {
                    window.location.href = url;
                }
            });

            // Add ringing animation to bell
            var bell = document.getElementById("bell");
            if (bell) {
                bell.classList.add("bell-ring");
                setTimeout(() => bell.classList.remove("bell-ring"), 1500);
            }

            // Update notification count badge
            var countElement = document.getElementById("notifCount");
            if (countElement) {
                var currentCount = parseInt(countElement.innerText) || 0;
                countElement.innerText = currentCount + 1;

                // Pop effect for badge
                countElement.classList.add("pop");
                setTimeout(() => countElement.classList.remove("pop"), 300);
            }

            // If on notifications page, we might want to refresh or append (handled in GetNotifications.cshtml)
            if (typeof onNotificationReceived === "function") {
                onNotificationReceived(message, url);
            }
        });

        connection.start().catch(function (err) {
            return console.error(err.toString());
        });



    function toggleMenu() {
         document.getElementById("navMenu").classList.toggle("active");
     }

    function brandClick(e) {
        let brand = e.currentTarget;

        // ripple effect
        let ripple = document.createElement("span");
        ripple.classList.add("ripple");

        let rect = brand.getBoundingClientRect();
        let size = Math.max(rect.width, rect.height);

        ripple.style.width = ripple.style.height = size + "px";
        ripple.style.left = (e.clientX - rect.left - size / 2) + "px";
        ripple.style.top = (e.clientY - rect.top - size / 2) + "px";

        brand.appendChild(ripple);

        setTimeout(() => {
            ripple.remove();
        }, 600);
    }
    // Toggle mobile menu
    function toggleMenu() {
        document.getElementById("navMenu").classList.toggle("active");
    }

    // Navbar shrink on scroll
    window.addEventListener("scroll", function () {
        let navbar = document.querySelector(".navbar");

        if (window.scrollY > 50) {
            navbar.classList.add("scrolled");
        } else {
            navbar.classList.remove("scrolled");
        }
    });


    // ⭐ fade-in cards on scroll
    const cards = document.querySelectorAll(".card");

    const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add("show");
            }
        });
    }, { threshold: 0.2 });

    cards.forEach(card => observer.observe(card));


    // ❤️ favorite toggle
    document.querySelectorAll(".fav").forEach(btn => {
        btn.addEventListener("click", () => {
            btn.classList.toggle("active");
            btn.style.background = btn.classList.contains("active") ? "#ff4d6d" : "white";
            btn.style.color = btn.classList.contains("active") ? "white" : "black";
        });
    });


    // 🔍 smooth search effect
    document.querySelector(".search-box button").addEventListener("click", () => {
        const input = document.querySelector(".search-box input");
        alert("Searching for: " + input.value);
    });
        // Scroll To Top
        // Scroll button
    const topBtn = document.getElementById("topBtn");

    window.addEventListener("scroll", () => {
        if (window.scrollY > 300) {
            topBtn.style.display = "block";
        } else {
            topBtn.style.display = "none";
        }
    });

    topBtn.onclick = () => {
        window.scrollTo({
            top: 0,
            behavior: "smooth"
        });
    };

    // Fade-in footer (simple animation)
    window.addEventListener("load", () => {
        const footer = document.querySelector(".footer");
        footer.style.opacity = 0;

        setTimeout(() => {
            footer.style.transition = "1s";
            footer.style.opacity = 1;
        }, 200);
    });
        document.getElementById("bell").addEventListener("click", async function () {

        const dropdown = document.getElementById("notifDropdown");

        dropdown.style.display =
            dropdown.style.display === "block" ? "none" : "block";

        const res = await fetch("/Notification/Get");

        const data = await res.json();

        dropdown.innerHTML = "";

        data.forEach(n => {
            dropdown.innerHTML += `
                <div style="padding:10px; border-bottom:1px solid #333;">
                    <a href="${n.url}" style="color:white;">
                        ${n.message}
                    </a>
                </div>
            `;
        });

    });
</script>





