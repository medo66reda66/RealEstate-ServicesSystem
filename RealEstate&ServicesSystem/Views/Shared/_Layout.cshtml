@using RealEstate_ServicesSystem.Utilities.DBinitializer
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Marketplace</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <link href="~/css/site.css" rel="stylesheet">
</head>

<body>
    <nav class="navbar">
        <div class="container nav-container">

            <!-- Brand -->
            <a href="/User/Home/Index" class="brand" onclick="brandClick(event)">
                <h3><span>🌍 Marketplace</span></h3>
            </a>

            <!-- Toggle (Mobile) -->
            <div class="menu-toggle" onclick="toggleMenu()">
                ☰
            </div>

            <!-- Menu -->
            <ul class="nav-menu" id="navMenu">

                @if (User.IsInRole(DS.Role_Admin))
                {
                    <li>
                        <a href="/Admin/Dashboard/Index" class="nav-link admin">
                            ⚙️ Dashboard
                        </a>
                    </li>
                }

                @if(User.IsInRole($"{DS.Role_Agent}"))
                {
                    <li>
                        <a href="/User/Home/MyListings" class="nav-link">
                            📋 My Listings
                        </a>
                    </li>
                }
                @if (User.IsInRole($"{DS.Role_User}"))
                {
                    <a href="/User/Home/Favorites" class="nav-link">
                        ❤️ Favorites
                    </a>
                }

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <li class="nav-item welcome">
                        👋 @User.Identity.Name
                    </li>

                    <li>
                        <a href="/Identity/Profile/Index" class="nav-link">
                            👤 Profile
                        </a>
                    </li>

                    <li>
                        <a href="/Identity/Account/Logout" class="nav-link logout">
                            🚪 Logout
                        </a>
                    </li>
                }
                else
                {
                    <li>
                        <a href="/Identity/Account/Register" class="nav-link register">
                            📝 Register
                        </a>
                    </li>

                    <li>
                        <a href="/Identity/Account/Login" class="nav-link login">
                            🔑 Login
                        </a>
                    </li>
                }
                @if(User.IsInRole($"{DS.Role_Agent}") || User.IsInRole($"{DS.Role_Owner}") || User.IsInRole($"{DS.Role_User}"))
                {
                    <a href="/User/Home/GetNotifications" class="notification-bell position-relative">
                        <i class="bi bi-bell" id="bell"></i>

                        <span class="badge bg-danger" id="notifCount">
                            @ViewBag.NotifCount
                        </span>
                    </a>
                }
            </ul>
        </div>
    </nav>

    @RenderBody()

    <footer class="footer">

        <div class="container footer-container">

            <!-- About -->
            <div class="footer-col">
                <h2 class="logo">🏢 EstateHub</h2>
                <p>
                    EstateHub is a modern real estate platform that helps property owners,
                    brokers, and buyers connect بسهولة واحترافية.
                </p>
                <p>
                    Our goal is to simplify property transactions and provide a trusted
                    digital experience للجميع.
                </p>
            </div>

            <!-- Services -->
            <div class="footer-col">
                <h4>Our Services</h4>
                <p>✔ Property Listings Management</p>
                <p>✔ Buy / Sell Properties</p>
                <p>✔ Broker Connectivity</p>
                <p>✔ Secure Transactions</p>
            </div>

            <!-- Contact -->
            <div class="footer-col">
                <h4>Contact Us</h4>
                <p>Email: support@estatehub.com</p>
                <p>Phone: +20 100 000 0000</p>
                <p>Location: Egypt</p>
            </div>

            <!-- Social -->
            <div class="footer-col">
                <h4>Follow Us</h4>
                <div class="socials">
                    <a href="#" class="social-btn">F</a>
                    <a href="#" class="social-btn">I</a>
                    <a href="#" class="social-btn">X</a>
                    <a href="#" class="social-btn">L</a>
                </div>
            </div>

        </div>

        <!-- Bottom -->
        <div class="footer-bottom">
            <p>© 2026 EstateHub — All Rights Reserved</p>
        </div>

        <!-- Scroll Top -->
        <button id="topBtn">↑</button>

    </footer>

 
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>
