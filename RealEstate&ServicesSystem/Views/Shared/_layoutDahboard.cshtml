@using RealEstate_ServicesSystem.Utilities.DBinitializer
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Real Estate Admin Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <style>
        body {
            background: #0b1220;
            color: #eaeaea;
            margin: 0;
        }

        /* SIDEBAR */
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            width: 250px;
            background: #111a2e;
            padding: 20px;
            overflow-y: auto;
        }

            .sidebar a {
                display: block;
                color: #aaa;
                padding: 10px;
                text-decoration: none;
                border-radius: 8px;
                margin-bottom: 8px;
            }

                .sidebar a:hover {
                    background: #1f2a44;
                    color: #fff;
                }

        /* MAIN CONTENT FIX */
        .main-content {
            margin-left: 250px;
            padding: 20px;
            min-height: 100vh;
        }

        .card-dark {
            background: #111a2e;
            border: none;
            border-radius: 15px;
        }

        .stat-box {
            background: #111a2e;
            padding: 20px;
            border-radius: 15px;
        }

        /* make renderbody full width inside main */
        .content-wrapper {
            width: 100%;
        }
    </style>
</head>
<body>
    @if (User.IsInRole($"{DS.Role_Admin}") || User.IsInRole($"{DS.Role_Employee}"))
    {
        <!-- SIDEBAR -->
        <div class="sidebar">
            <h4 class="text-white mb-4">🏠 RealEstate</h4>
     
                <a href="/Admin/Dashboard/Index">Dashboard</a>
                <a href="/Admin/Property/Allproperty">Properties</a>
                <a href="/Admin/Unit/Allunit">Units</a>
                <a href="/Admin/Listing/AllListing">Listings</a>
                <a href="/Admin/UserRequest/Index">Requests</a>
                <a href="/Admin/User/Index">Users</a>
                <a href="/Admin/Review/Index">Reviews</a>
                <a href="/User/Home/Index" class="btn btn-primary">
                    Back Marketplace
                </a>
        </div>
    }else
    {
        <div class="sidebar">
            <h4 class="text-white mb-4">🏠 RealEstate</h4>
            <p style="color:gray;">Welcome to Real Estate System</p>
            <a href="/User/Home/Index" class="btn btn-primary">
                Browse Properties
            </a>
        </div>
    }
    <!-- MAIN -->
    <div class="main-content">
        <div class="content-wrapper">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>